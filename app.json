{
  "expo": {
    "name": "CulturePass",
    "slug": "culturepass-australia",
    "owner": "culturestudios",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "culturepass",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.com.culturepass.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:culturepass.au",
        "applinks:www.culturepass.au"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CulturePass Australia uses your location to show cultural events, creative businesses, and venues in your local area.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CulturePass Australia uses your location to show cultural events, creative businesses, and venues in your local area.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "au.com.culturepass.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "culturepass.au",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.culturepass.au",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF6EF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "backgroundColor": "#FAF6EF",
          "resizeMode": "contain"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86f81a40-2734-4f47-a1b2-02d4d7c8431d"
      }
    }
  }
}

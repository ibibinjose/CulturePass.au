# CulturePass Australia — environment
# Copy to .env and fill in. Only EXPO_PUBLIC_* vars are exposed to the client.
# NEVER put the service_role / secret key in any EXPO_PUBLIC_ var.

# Backend selector (lib/backend.ts): "supabase" (default) or "aws".
# Flip to "aws" only after deploying Amplify + filling the values below.
EXPO_PUBLIC_BACKEND=supabase

# AWS / Amplify (client-side). Expo only inlines EXPO_PUBLIC_* — NOT VITE_*.
# Fill from amplify_outputs.json after `npx ampx sandbox`. See docs/AWS_MIGRATION.md.
EXPO_PUBLIC_AWS_REGION=ap-southeast-2
EXPO_PUBLIC_COGNITO_USER_POOL_ID=your_cognito_user_pool_id
EXPO_PUBLIC_COGNITO_APP_CLIENT_ID=your_cognito_app_client_id
EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID=your_cognito_identity_pool_id
EXPO_PUBLIC_APPSYNC_ENDPOINT=your_appsync_graphql_endpoint
# EXPO_PUBLIC_APPSYNC_API_KEY=          # only if you add an apiKey auth mode
EXPO_PUBLIC_S3_BUCKET=your_s3_bucket_name
EXPO_PUBLIC_CLOUDFRONT_DOMAIN=your_cloudfront_domain

# Optional: Mapbox for maps (public token is safe to expose).
EXPO_PUBLIC_MAPBOX_TOKEN=

# -----------------------------------------------------------------------------
# Stripe ticketing — these are SERVER-SIDE secrets for the Edge Functions only.
# They are NOT EXPO_PUBLIC_ and must never ship in the app bundle. Set them on
# Supabase with `supabase secrets set` (see docs/STRIPE_TICKETING.md):
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   SITE_URL=http://localhost:8081   # base URL Stripe redirects back to
# -----------------------------------------------------------------------------

# CulturePass Australia — environment
# Copy to .env and fill in. Only EXPO_PUBLIC_* vars are exposed to the client.
# NEVER put the service_role / secret key in any EXPO_PUBLIC_ var.

VITE_COGNITO_USER_POOL_ID=your_cognito_user_pool_id
VITE_COGNITO_APP_CLIENT_ID=your_cognito_app_client_id
VITE_AWS_REGION=your_aws_region
VITE_S3_BUCKET=your_s3_bucket_name
VITE_CLOUDFRONT_DOMAIN=your_cloudfront_domain

# Optional: Mapbox for maps (public token is safe to expose).
EXPO_PUBLIC_MAPBOX_TOKEN=

# -----------------------------------------------------------------------------
# Stripe ticketing — these are SERVER-SIDE secrets for the Edge Functions only.
# They are NOT EXPO_PUBLIC_ and must never ship in the app bundle. Set them on
# Supabase with `supabase secrets set` (see docs/STRIPE_TICKETING.md):
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   SITE_URL=http://localhost:8081   # base URL Stripe redirects back to
# -----------------------------------------------------------------------------

# CulturePass Australia — environment
# Copy to .env and fill in values from amplify_outputs.json.
# Only EXPO_PUBLIC_* vars are exposed to the client bundle.
# NEVER put AWS secret keys or Stripe secrets in any EXPO_PUBLIC_ var.
#
# To populate the AWS values automatically after deploying the backend:
#   node scripts/aws-env-from-outputs.mjs

# Backend — AWS only.
EXPO_PUBLIC_BACKEND=aws

# AWS / Amplify (client-side, from amplify_outputs.json).
EXPO_PUBLIC_AWS_REGION=ap-southeast-2
EXPO_PUBLIC_COGNITO_USER_POOL_ID=your_cognito_user_pool_id
EXPO_PUBLIC_COGNITO_APP_CLIENT_ID=your_cognito_app_client_id
EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID=your_cognito_identity_pool_id
EXPO_PUBLIC_APPSYNC_ENDPOINT=your_appsync_graphql_endpoint
EXPO_PUBLIC_S3_BUCKET=your_s3_bucket_name
# EXPO_PUBLIC_CLOUDFRONT_DOMAIN=your_cloudfront_domain   # optional — add once a distribution is created

# Optional: Mapbox for maps (public token is safe to expose).
EXPO_PUBLIC_MAPBOX_TOKEN=

# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS — never EXPO_PUBLIC_*, never in the app bundle.
# Set these on the Amplify backend with:
#   npx ampx sandbox secret set STRIPE_SECRET_KEY
#   npx ampx sandbox secret set STRIPE_WEBHOOK_SECRET
#
#   STRIPE_SECRET_KEY=sk_live_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
# ---------------------------------------------------------------------------

{
  "name": "culturepass-australia",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "data:lgas": "node scripts/extract-australian-lgas.mjs --write",
    "backup": "node scripts/backup.mjs",
    "migrate:dynamo": "node scripts/migrate-supabase-to-dynamo.mjs",
    "migrate:dynamo:dry": "DRY_RUN=1 node scripts/migrate-supabase-to-dynamo.mjs"
  },

  "dependencies": {
    "@expo-google-fonts/inter": "0.2.3",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@tanstack/react-query": "5.59.0",
    "aws-amplify": "^6.18.0",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "nativewind": "4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-date-picker": "^5.0.13",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "2.0.0",
    "react-native-web": "~0.20.0",
    "tailwindcss": "3.4.14",
    "zod": "3.23.8",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.0",
